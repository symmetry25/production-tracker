# Database
DATABASE_URL="postgresql://user:password@localhost:5432/production_tracker?schema=public"

# Auth
AUTH_SECRET="your-long-random-secret-here"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-long-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Set true only for public demo deployments without DATABASE_URL.
DEMO_LOGIN_ENABLED=false

# File uploads
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB=500

# S3 production storage
USE_S3=false
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=production-tracker-media
S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional assignment email notifications
# Uses Resend REST API when enabled. Leave key/from empty to keep local demo mode silent.
NOTIFICATIONS_ENABLED=true
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL="Production Tracker <notifications@example.com>"
NEXT_PUBLIC_APP_URL="http://localhost:3100"

# AI recognition and schedule suggestions
# Leave empty for mock/rules mode.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
