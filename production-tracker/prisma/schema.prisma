generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PRODUCER
  SUPERVISOR
  ARTIST
  REVIEWER
}

enum TaskStatus {
  WAITING_TO_START
  READY_TO_START
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  FINAL
  ON_HOLD
  OMIT
}

enum DependencyType {
  FS
  FF
  SS
  SF
}

enum AssetType {
  CHARACTER
  ENVIRONMENT
  PROP
  FX
  VEHICLE
  RIG
}

enum CalendarExceptionType {
  HOLIDAY
  REDUCED_HOURS
  STUDIO_CLOSURE
}

enum VersionStatus {
  PENDING_REVIEW
  VIEWED
  APPROVED
  CHANGES_REQUESTED
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String?
  role       Role     @default(ARTIST)
  department String?
  avatarUrl  String?
  capacity   Int      @default(5)
  createdAt  DateTime @default(now())

  assignments      Assignment[]
  uploadedVersions Version[]
  notes            Note[]
  scores           UserScore[]
  userGrade        UserGrade?
  userSkills       UserSkill[]
}

model Project {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  thumbnailUrl  String?
  description   String?
  startDate     DateTime
  dueDate       DateTime
  milestone     String?
  milestoneDate DateTime?
  status        String   @default("active")
  isTemplate    Boolean  @default(false)
  createdAt     DateTime @default(now())

  shots         Shot[]
  assets        Asset[]
  sequences     Sequence[]
  phases        Phase[]
  workOrders    WorkOrder[]
  calExceptions CalendarException[]
  entityTypes   EntityType[]
  dashboards    Dashboard[]
}

model Sequence {
  id          String     @id @default(cuid())
  code        String
  description String?
  status      TaskStatus @default(WAITING_TO_START)
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots       Shot[]

  @@unique([projectId, code])
}

model Shot {
  id           String     @id @default(cuid())
  code         String
  description  String?
  cutIn        Int?
  cutOut       Int?
  cutDuration  Int?
  status       TaskStatus @default(WAITING_TO_START)
  thumbnailUrl String?
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sequenceId   String?
  sequence     Sequence?  @relation(fields: [sequenceId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  tasks        Task[]
  linkedAssets ShotAsset[]

  @@unique([projectId, code])
}

model Asset {
  id           String     @id @default(cuid())
  name         String
  type         AssetType
  status       TaskStatus @default(WAITING_TO_START)
  description  String?
  thumbnailUrl String?
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  tasks       Task[]
  linkedShots ShotAsset[]
  notes       Note[]
}

model ShotAsset {
  shotId  String
  assetId String
  shot    Shot   @relation(fields: [shotId], references: [id], onDelete: Cascade)
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([shotId, assetId])
}

model Task {
  id            String     @id @default(cuid())
  name          String
  status        TaskStatus @default(WAITING_TO_START)
  priority      Int        @default(0)
  startDate     DateTime?
  dueDate       DateTime?
  duration      Int?
  timeLogged    Float      @default(0)
  estimatedCost Float?
  shotId        String?
  shot          Shot?      @relation(fields: [shotId], references: [id], onDelete: Cascade)
  assetId       String?
  asset         Asset?     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  phaseId       String?
  phase         Phase?     @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  assignments  Assignment[]
  versions     Version[]
  notes        Note[]
  predecessors TaskDependency[] @relation("successor")
  successors   TaskDependency[] @relation("predecessor")
}

model TaskDependency {
  id            String         @id @default(cuid())
  predecessorId String
  predecessor   Task           @relation("predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     Task           @relation("successor", fields: [successorId], references: [id], onDelete: Cascade)
  type          DependencyType @default(FS)
  lagDays       Int            @default(0)

  @@unique([predecessorId, successorId])
}

model Assignment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewerId String?
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
}

model Version {
  id           String        @id @default(cuid())
  number       Int
  name         String
  status       VersionStatus @default(PENDING_REVIEW)
  taskId       String
  task         Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User          @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  fileUrl      String
  fileType     String
  thumbnailUrl String?
  description  String?
  frameCount   Int?
  fps          Float?        @default(24)
  createdAt    DateTime      @default(now())

  notes Note[]

  @@unique([taskId, number])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assetId   String?
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  versionId String?
  version   Version? @relation(fields: [versionId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Phase {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model WorkOrder {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("open")
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model CalendarException {
  id            String                @id @default(cuid())
  date          DateTime
  type          CalendarExceptionType
  description   String?
  hoursWorked   Int                   @default(0)
  projectId     String?
  project       Project?              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inheritedFrom String?
}

model EntityType {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  isTemplate  Boolean  @default(false)
  industry    String?
  createdBy   String
  createdAt   DateTime @default(now())

  fields  FieldDef[]
  records EntityRecord[]
}

model FieldDef {
  id           String     @id @default(cuid())
  entityTypeId String
  entityType   EntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  name         String
  key          String
  type         String
  required     Boolean    @default(false)
  defaultValue Json?
  options      Json?
  config       Json?
  order        Int        @default(0)
  width        Int?
  hidden       Boolean    @default(false)
  readOnly     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([entityTypeId, key])
}

model EntityRecord {
  id           String     @id @default(cuid())
  entityTypeId String
  entityType   EntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  data         Json
  autoNumber   Int?
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  files   RecordFile[]
  notes   RecordNote[]
  aiScans AiScan[]
}

model RecordFile {
  id         String       @id @default(cuid())
  recordId   String
  record     EntityRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  filename   String
  fileUrl    String
  fileType   String
  fileSize   Int
  uploadedAt DateTime     @default(now())
}

model RecordNote {
  id        String       @id @default(cuid())
  recordId  String
  record    EntityRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  content   String
  authorId  String
  createdAt DateTime     @default(now())
}

model AiScan {
  id           String        @id @default(cuid())
  recordId     String?
  record       EntityRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)
  entityTypeId String?
  mode         String
  imageUrl     String
  rawResult    Json
  appliedData  Json?
  confidence   Float?
  createdAt    DateTime      @default(now())
}

model Dashboard {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  widgets DashboardWidget[]
}

model DashboardWidget {
  id          String    @id @default(cuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  config      Json
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}

model ScoreDimension {
  id          String   @id @default(cuid())
  name        String
  description String?
  weight      Float    @default(1.0)
  maxScore    Int      @default(100)
  minScore    Int      @default(0)
  category    String?
  projectId   String?
  createdAt   DateTime @default(now())

  scores UserScore[]
}

model UserScore {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dimensionId String
  dimension   ScoreDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  score       Float
  comment     String?
  scoredById  String
  scoredAt    DateTime       @default(now())
  period      String

  @@unique([userId, dimensionId, period])
}

model GradeLevel {
  id         String   @id @default(cuid())
  name       String
  code       String
  department String?
  minScore   Float
  maxScore   Float
  salaryMin  Float?
  salaryMax  Float?
  color      String
  benefits   String[]
  createdAt  DateTime @default(now())

  users UserGrade[]
}

model UserGrade {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gradeId       String
  grade         GradeLevel @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  effectiveDate DateTime
  expireDate    DateTime?
  note          String?
  setById       String
  createdAt     DateTime   @default(now())
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  category  String
  createdAt DateTime @default(now())

  userSkills UserSkill[]
}

model UserSkill {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  level      Int
  verifiedBy String?
  verifiedAt DateTime?
  updatedAt  DateTime @updatedAt

  @@unique([userId, skillId])
}
